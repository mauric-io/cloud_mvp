Todo sobre Sociedad",225,1490,ok,,b4b7d706b3feddbf6c0b86ec6f44580eaa5a1cc05b063640b5117edd5f6949ca,b4b7d706b3feddbf6c0b86ec6f44580eaa5a1cc05b063640b5117edd5f6949ca,"{""temas"": [""Empresas"", ""Infraestructura"", ""Laboral"", ""Política"", ""Regiones"", ""Seguridad"", ""Tecnología""], ""empresas_sectores"": [""Transporte""], ""entidades"": [""Gobierno""], ""regiones"": [""Metropolitana""], ""tagger"": ""local_keyword_v1""}",{},5,py_only,local_keyword_v1,/Users/mauricio/news_engine_tools/scrape_outlets/data/runs/2026-06-13/master_learned_v2_regiones-ex-useless/raw/articles_master_learned_v2_reg_2026-06-13.csv
